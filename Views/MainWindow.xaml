<Window x:Class="BulkImageGenerator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BulkImageGenerator.ViewModels"
        xmlns:conv="clr-namespace:BulkImageGenerator.Converters"
        Title="{Binding CurrentTemplate.Name, StringFormat='Bulk Image Generator — {0}'}"
        Height="820" Width="1280"
        MinHeight="640" MinWidth="960"
        Background="#1E1E2E">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />

        <!-- ══ COLOR PALETTE ══════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="SurfaceBrush"    Color="#2A2A3E"/>
        <SolidColorBrush x:Key="PanelBrush"      Color="#313148"/>
        <SolidColorBrush x:Key="AccentBrush"     Color="#7C6FE0"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#9B8FFF"/>
        <SolidColorBrush x:Key="DangerBrush"     Color="#E05C5C"/>
        <SolidColorBrush x:Key="TextPrimary"     Color="#EEEEF5"/>
        <SolidColorBrush x:Key="TextSecondary"   Color="#9090AA"/>
        <SolidColorBrush x:Key="BorderBrush"     Color="#44445A"/>
        <SolidColorBrush x:Key="SelectionBrush"  Color="#7C6FE0"/>

        <!-- ══ BUTTON STYLE ═══════════════════════════════════════════════════ -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="12,6"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource AccentButton}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource AccentButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        </Style>

        <!-- ══ SECTION LABEL STYLE ════════════════════════════════════════════ -->
        <!-- ✅ FIXED: Pure WPF properties only -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Margin"       Value="0,12,0,4"/>
            <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
        </Style>

        <!-- ══ INPUT STYLE ════════════════════════════════════════════════════ -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"  Value="#1E1E2E"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"     Value="6,4"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="CaretBrush"  Value="{StaticResource AccentBrush}"/>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background"  Value="#1E1E2E"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding"     Value="6,4"/>
            <Setter Property="FontSize"    Value="12"/>
        </Style>

        <!-- ══ PLACEHOLDER ITEM TEMPLATE ══════════════════════════════════════
             Each placeholder is rendered as a semi-transparent bordered rectangle
             on the canvas. When selected, it shows resize handles (8 Thumbs).
             The ItemContainerStyle sets Canvas.Left/Top for positioning.       -->
        <DataTemplate x:Key="PlaceholderTemplate" DataType="{x:Type vm:PlaceholderViewModel}">
            <Grid x:Name="PlaceholderRoot"
                  Width="{Binding Width}"
                  Height="{Binding Height}"
                  Cursor="SizeAll"
                  Tag="{Binding}">

                <!-- ── Body: colored border showing type ── -->
                <Border x:Name="PlaceholderBorder"
                        BorderThickness="1.5"
                        CornerRadius="2"
                        Background="#33FFFFFF">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#7C6FE0" Opacity="0.8"/>
                    </Border.BorderBrush>

                    <!-- Variable name label -->
                    <TextBlock Text="{Binding DisplayLabel}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="NoWrap"
                               Opacity="0.9"/>
                </Border>

                <!-- ── Selection highlight overlay ── -->
                <Border x:Name="SelectionBorder"
                        BorderThickness="2"
                        CornerRadius="2"
                        BorderBrush="{StaticResource SelectionBrush}"
                        Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}"/>

                <!-- ── Resize handles (8-point, shown only when selected) ──
                     Thumbs are placed at corners and edge midpoints.
                     DragDelta events are handled in code-behind (pure view logic).
                     Tags encode which handle: "TL","TC","TR","ML","MR","BL","BC","BR" -->
                <Canvas x:Name="ResizeHandles"
                        Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}">

                    <!-- Top-Left -->
                    <Thumb Canvas.Left="-5" Canvas.Top="-5"
                           Width="10" Height="10"
                           Tag="TL" Cursor="SizeNWSE"
                           Style="{StaticResource ResizeThumbStyle}"/>
                    <!-- Top-Center -->
                    <Thumb Canvas.Left="{Binding HalfWidthOffset}" Canvas.Top="-5"
                           Width="10" Height="10"
                           Tag="TC" Cursor="SizeNS"
                           Style="{StaticResource ResizeThumbStyle}"/>
                    <!-- Top-Right -->
                    <Thumb Canvas.Left="{Binding WidthOffset}" Canvas.Top="-5"
                           Width="10" Height="10"
                           Tag="TR" Cursor="SizeNESW"
                           Style="{StaticResource ResizeThumbStyle}"/>
                    <!-- Middle-Left -->
                    <Thumb Canvas.Left="-5" Canvas.Top="{Binding HalfHeightOffset}"
                           Width="10" Height="10"
                           Tag="ML" Cursor="SizeWE"
                           Style="{StaticResource ResizeThumbStyle}"/>
                    <!-- Middle-Right -->
                    <Thumb Canvas.Left="{Binding WidthOffset}" Canvas.Top="{Binding HalfHeightOffset}"
                           Width="10" Height="10"
                           Tag="MR" Cursor="SizeWE"
                           Style="{StaticResource ResizeThumbStyle}"/>
                    <!-- Bottom-Left -->
                    <Thumb Canvas.Left="-5" Canvas.Top="{Binding HeightOffset}"
                           Width="10" Height="10"
                           Tag="BL" Cursor="SizeNESW"
                           Style="{StaticResource ResizeThumbStyle}"/>
                    <!-- Bottom-Center -->
                    <Thumb Canvas.Left="{Binding HalfWidthOffset}" Canvas.Top="{Binding HeightOffset}"
                           Width="10" Height="10"
                           Tag="BC" Cursor="SizeNS"
                           Style="{StaticResource ResizeThumbStyle}"/>
                    <!-- Bottom-Right -->
                    <Thumb Canvas.Left="{Binding WidthOffset}" Canvas.Top="{Binding HeightOffset}"
                           Width="10" Height="10"
                           Tag="BR" Cursor="SizeNWSE"
                           Style="{StaticResource ResizeThumbStyle}"/>
                </Canvas>
            </Grid>
        </DataTemplate>

        <!-- Resize Thumb visual style (small square handle) -->
        <Style x:Key="ResizeThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{StaticResource AccentBrush}"
                                BorderBrush="White"
                                BorderThickness="1"
                                CornerRadius="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════════════════
         ROOT LAYOUT: Menu + 3-Column Body + Status Bar
         ════════════════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>    <!-- Menu Bar -->
            <RowDefinition Height="*"/>     <!-- Main Body -->
            <RowDefinition Height="36"/>    <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- ══ MENU BAR ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">

                <TextBlock Text="🎨" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Bulk Image Generator"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,24,0"/>

                <Button Content="📂 New / Load Template"
                        Command="{Binding LoadTemplateCommand}"
                        Style="{StaticResource GhostButton}" Margin="2,0"/>
                <Button Content="💾 Save Template"
                        Command="{Binding SaveTemplateCommand}"
                        Style="{StaticResource GhostButton}" Margin="2,0"/>
                <Separator Background="{StaticResource BorderBrush}" Width="1" Margin="8,6"/>
                <Button Content="🖼 Background Image"
                        Command="{Binding LoadBackgroundImageCommand}"
                        Style="{StaticResource GhostButton}" Margin="2,0"/>
            </StackPanel>
        </Border>

        <!-- ══ MAIN BODY (3 columns) ═══════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>         <!-- Left: Tools Panel -->
                <ColumnDefinition Width="*"/>           <!-- Center: Canvas -->
                <ColumnDefinition Width="260"/>         <!-- Right: Properties Panel -->
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────────────────────────────────────
                 LEFT PANEL: Tools + Excel Import + Generate
                 ───────────────────────────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">

                        <!-- Section: Placeholders -->
                        <TextBlock Text="PLACEHOLDERS" Style="{StaticResource SectionLabel}"/>

                        <Button Content="＋ Add Text Block"
                                Command="{Binding AddTextPlaceholderCommand}"
                                Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,6"/>

                        <Button Content="＋ Add Image Box"
                                Command="{Binding AddImagePlaceholderCommand}"
                                Style="{StaticResource AccentButton}"
                                Background="#4E7FD4"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,6"/>

                        <Button Content="🗑 Delete Selected"
                                Command="{Binding DeleteSelectedPlaceholderCommand}"
                                Style="{StaticResource DangerButton}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,4"/>

                        <!-- Section: Canvas Size -->
                        <TextBlock Text="CANVAS SIZE" Style="{StaticResource SectionLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition Width="Auto"/>
                                <ColumnDefinition/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding CurrentTemplate.CanvasWidth, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="1" Text=" × "
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="2,0"/>
                            <TextBox Grid.Column="2"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding CurrentTemplate.CanvasHeight, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="3" Text=" px"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="2,0"/>
                        </Grid>

                        <!-- Section: Output Settings -->
                        <TextBlock Text="OUTPUT" Style="{StaticResource SectionLabel}"/>

                        <TextBlock Text="Format" Foreground="{StaticResource TextSecondary}"
                                   FontSize="11" Margin="0,0,0,2"/>
                        <ComboBox Style="{StaticResource DarkComboBox}"
                                  SelectedValue="{Binding CurrentTemplate.OutputFormat}"
                                  SelectedValuePath="Content">
                            <ComboBoxItem Content="jpeg"/>
                            <ComboBoxItem Content="png"/>
                        </ComboBox>

                        <TextBlock Text="JPEG Quality (1-100)"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11" Margin="0,8,0,2"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" Minimum="1" Maximum="100"
                                    Value="{Binding CurrentTemplate.OutputQuality}"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CurrentTemplate.OutputQuality}"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center"
                                       Margin="4,0,0,0"/>
                        </Grid>

                        <TextBlock Text="Output Filename Column"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11" Margin="0,8,0,2"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding FileNameColumn, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Excel column to use as the output filename (optional)"/>

                        <!-- Section: Excel -->
                        <TextBlock Text="EXCEL DATA" Style="{StaticResource SectionLabel}"/>

                        <Button Content="📊 Import Excel (.xlsx / .xls)"
                                Command="{Binding ImportExcelCommand}"
                                Style="{StaticResource AccentButton}"
                                Background="#3D8A6E"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,4"/>

                        <Border Background="#1E1E2E" CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                            <StackPanel>
                                <TextBlock Text="{Binding ExcelFileName}"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="11" TextWrapping="Wrap"/>
                                <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="10"
                                           Margin="0,2,0,0">
                                    <Run Text="{Binding ExcelRowCount, Mode=OneWay}"/>
                                    <Run Text=" rows detected"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Section: Output Directory -->
                        <TextBlock Text="OUTPUT FOLDER" Style="{StaticResource SectionLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding OutputDirectory}"
                                     IsReadOnly="True"
                                     FontSize="10"/>
                            <Button Grid.Column="1" Content="…"
                                    Command="{Binding BrowseOutputDirectoryCommand}"
                                    Style="{StaticResource GhostButton}"
                                    Margin="4,0,0,0" Padding="8,4"/>
                        </Grid>

                        <!-- Section: Generate -->
                        <TextBlock Text="GENERATE" Style="{StaticResource SectionLabel}"/>

                        <Button Content="⚡ Generate All Images"
                                Command="{Binding GenerateAllCommand}"
                                Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,6"
                                FontSize="13" Padding="12,10"
                                IsEnabled="{Binding IsGenerating,
                                    Converter={StaticResource BoolToVisibility},
                                    ConverterParameter=Inverse}"/>

                        <Button Content="⛔ Cancel"
                                Command="{Binding GenerateAllCancelCommand}"
                                Style="{StaticResource DangerButton}"
                                HorizontalAlignment="Stretch"
                                Visibility="{Binding IsGenerating,
                                    Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Progress -->
                        <ProgressBar Height="8"
                                     Margin="0,8,0,4"
                                     Minimum="0"
                                     Maximum="{Binding ProgressMax}"
                                     Value="{Binding ProgressValue}"
                                     Background="#1E1E2E"
                                     Foreground="{StaticResource AccentBrush}"/>

                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="10"
                                   TextWrapping="Wrap"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ─────────────────────────────────────────────────────────────────
                 CENTER PANEL: Template Canvas Editor
                 ───────────────────────────────────────────────────────────────── -->
            <Border Grid.Column="1" Background="#16161F">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              x:Name="CanvasScrollViewer">

                    <!-- The outer container centers the canvas in the scroll area -->
                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="40">

                        <!-- Drop shadow effect for the canvas -->
                        <Border Background="Transparent" Margin="4">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="20"
                                                  ShadowDepth="4" Opacity="0.6"/>
                            </Border.Effect>

                            <!-- ── The template canvas ──
                                 Width/Height bind to the template's output pixel dimensions.
                                 The background Image fills the canvas.
                                 The ItemsControl overlays placeholder boxes.            -->
                            <Grid Width="{Binding CanvasWidth}"
                                  Height="{Binding CanvasHeight}"
                                  ClipToBounds="True"
                                  x:Name="TemplateCanvasRoot">

                                <!-- Background image fill -->
                                <Image Source="{Binding BackgroundImagePath}"
                                       Stretch="Fill"
                                       IsHitTestVisible="False"/>

                                <!-- Checkerboard fallback when no background is loaded -->
                                <Border Background="Transparent"
                                        IsHitTestVisible="False"
                                        Visibility="{Binding BackgroundImagePath,
                                            Converter={StaticResource BoolToVisibility},
                                            ConverterParameter=Inverse}">
                                    <TextBlock Text="Click 'Background Image' to load a template background"
                                               Foreground="#44444A"
                                               FontSize="14" FontStyle="Italic"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- ── Placeholder ItemsControl ──
                                     ItemsPanel is a Canvas so placeholders are positioned absolutely.
                                     ItemContainerStyle sets Canvas.Left/Top from the VM's Left/Top.
                                     This is the correct WPF binding pattern for canvas item placement [web:21]. -->
                                <ItemsControl ItemsSource="{Binding Placeholders}"
                                              ItemTemplate="{StaticResource PlaceholderTemplate}"
                                              x:Name="PlaceholdersControl">

                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas IsHitTestVisible="True"
                                                    Background="Transparent"
                                                    MouseDown="Canvas_MouseDown"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <!-- KEY: Canvas.Left/Top must be set on the ContentPresenter
                                         (direct child of Canvas), NOT inside the DataTemplate.
                                         This is the canonical solution from Stack Overflow [web:24]. -->
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                            <Setter Property="Canvas.Top"  Value="{Binding Top}"/>
                                            <EventSetter Event="MouseDown"
                                                         Handler="PlaceholderItem_MouseDown"/>
                                            <EventSetter Event="MouseMove"
                                                         Handler="PlaceholderItem_MouseMove"/>
                                            <EventSetter Event="MouseUp"
                                                         Handler="PlaceholderItem_MouseUp"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>

                                </ItemsControl>

                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Border>

            <!-- ─────────────────────────────────────────────────────────────────
                 RIGHT PANEL: Properties Editor
                 ───────────────────────────────────────────────────────────────── -->
            <!-- ✅ FIXED: Border has one child (Grid), Grid holds both children -->
<Border Grid.Column="2"
        Background="{StaticResource PanelBrush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1,0,0,0">

    <!-- Single child: a Grid that stacks both panels -->
    <Grid>

        <!-- "No Selection" message — visible when nothing is selected -->
        <TextBlock Text="Select a placeholder&#10;to edit its properties."
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="13" FontStyle="Italic"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding HasSelection,
                       Converter={StaticResource BoolToVisibility},
                       ConverterParameter=Inverse}"/>

        <!-- Properties ScrollViewer — visible when a placeholder is selected -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding HasSelection,
                          Converter={StaticResource BoolToVisibility}}">
            <StackPanel Margin="14" DataContext="{Binding SelectedPlaceholder}">

                <TextBlock Text="PLACEHOLDER PROPERTIES"
                           Style="{StaticResource SectionLabel}"
                           Margin="0,4,0,8"/>

                <!-- Variable Name -->
                <TextBlock Text="Variable Name (maps to Excel column)"
                           Foreground="{StaticResource TextSecondary}" FontSize="11"
                           Margin="0,0,0,2"/>
                <TextBox Style="{StaticResource DarkTextBox}"
                         Text="{Binding VariableName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,8"/>

                <!-- Type selector -->
                <TextBlock Text="Type"
                           Foreground="{StaticResource TextSecondary}" FontSize="11"
                           Margin="0,0,0,2"/>
                <ComboBox Style="{StaticResource DarkComboBox}"
                          SelectedValue="{Binding Type}"
                          SelectedValuePath="Content"
                          Margin="0,0,0,12">
                    <ComboBoxItem Content="text"/>
                    <ComboBoxItem Content="image"/>
                </ComboBox>

                <!-- Position & Size -->
                <TextBlock Text="POSITION &amp; SIZE"
                           Style="{StaticResource SectionLabel}"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/><RowDefinition/>
                        <RowDefinition/><RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,4,2"/>
                    <TextBox Grid.Row="1" Grid.Column="0"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding Left, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,4,6"/>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Y"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,2"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding Top, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Width"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,4,2"/>
                    <TextBox Grid.Row="3" Grid.Column="0"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,4,0"/>

                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Height"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,2"/>
                    <TextBox Grid.Row="3" Grid.Column="1"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <!-- TEXT STYLE SECTION -->
                <StackPanel Visibility="{Binding DataContext.IsTextSelected,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={StaticResource BoolToVisibility}}">

                    <TextBlock Text="TEXT STYLE" Style="{StaticResource SectionLabel}"/>

                    <TextBlock Text="Font Family"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,2"/>
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding FontFamily, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,6"/>

                    <TextBlock Text="Font Size (pt)"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,2"/>
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,6"/>

                    <TextBlock Text="Color (#AARRGGBB)"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,2"/>
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding TextColor, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,6"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox Content="Bold"
                                  IsChecked="{Binding IsBold}"
                                  Foreground="{StaticResource TextPrimary}"
                                  Margin="0,0,16,0"/>
                        <CheckBox Content="Italic"
                                  IsChecked="{Binding IsItalic}"
                                  Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>

                    <TextBlock Text="Horizontal Alignment"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,2"/>
                    <ComboBox Style="{StaticResource DarkComboBox}"
                              SelectedValue="{Binding Alignment}"
                              SelectedValuePath="Content"
                              Margin="0,0,0,6">
                        <ComboBoxItem Content="left"/>
                        <ComboBoxItem Content="center"/>
                        <ComboBoxItem Content="right"/>
                    </ComboBox>

                    <TextBlock Text="Vertical Alignment"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,2"/>
                    <ComboBox Style="{StaticResource DarkComboBox}"
                              SelectedValue="{Binding VerticalAlignment}"
                              SelectedValuePath="Content"
                              Margin="0,0,0,6">
                        <ComboBoxItem Content="top"/>
                        <ComboBoxItem Content="middle"/>
                        <ComboBoxItem Content="bottom"/>
                    </ComboBox>

                    <CheckBox Content="Word Wrap"
                              IsChecked="{Binding WordWrap}"
                              Foreground="{StaticResource TextPrimary}"
                              Margin="0,0,0,8"/>
                </StackPanel>

                <!-- IMAGE STYLE SECTION -->
                <StackPanel Visibility="{Binding DataContext.IsImageSelected,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={StaticResource BoolToVisibility}}">

                    <TextBlock Text="IMAGE STYLE" Style="{StaticResource SectionLabel}"/>

                    <TextBlock Text="Fit Mode"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,2"/>
                    <ComboBox Style="{StaticResource DarkComboBox}"
                              SelectedValue="{Binding FitMode}"
                              SelectedValuePath="Content"
                              Margin="0,0,0,6">
                        <ComboBoxItem Content="cover"/>
                        <ComboBoxItem Content="contain"/>
                        <ComboBoxItem Content="stretch"/>
                    </ComboBox>

                    <TextBlock Text="Corner Radius (px)"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,2"/>
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding CornerRadius, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="0 = sharp corners. Use half of width/height for a circle."/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Border>

        </Grid>

        <!-- ══ STATUS BAR ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11"
                           VerticalAlignment="Center">
                    <Run Text="{Binding ProgressValue, Mode=OneWay}"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding ProgressMax, Mode=OneWay}"/>
                    <Run Text=" images"/>
                </TextBlock>
            </Grid>
        </Border>

    </Grid>
</Window>
