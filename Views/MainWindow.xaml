<Window x:Class="BulkImageGenerator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:BulkImageGenerator.Converters"
        Title="CardForge - Bulk File Generator"
        Height="820" Width="1280"
        MinHeight="640" MinWidth="960"
        Background="#1E1E2E">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Colors -->
        <SolidColorBrush x:Key="SurfaceBrush"     Color="#2A2A3E"/>
        <SolidColorBrush x:Key="PanelBrush"       Color="#313148"/>
        <SolidColorBrush x:Key="AccentBrush"      Color="#7C6FE0"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#9B8FFF"/>
        <SolidColorBrush x:Key="DangerBrush"      Color="#E05C5C"/>
        <SolidColorBrush x:Key="SuccessBrush"     Color="#3D8A6E"/>
        <SolidColorBrush x:Key="TextPrimary"      Color="#EEEEF5"/>
        <SolidColorBrush x:Key="TextSecondary"    Color="#9090AA"/>
        <SolidColorBrush x:Key="BorderBrush"      Color="#44445A"/>

        <!-- Accent Button -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,7"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource AccentButton}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource AccentButton}">
            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource AccentButton}">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
        </Style>

        <!-- Section label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,14,0,4"/>
            <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
        </Style>

        <!-- Dark TextBox -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#1E1E2E"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,5"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="CaretBrush"      Value="{StaticResource AccentBrush}"/>
        </Style>

        <!-- Dark ComboBox — full restyle including dropdown items -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background"             Value="#1E1E2E"/>
            <Setter Property="Foreground"             Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"            Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness"        Value="1"/>
            <Setter Property="Padding"                Value="6,5"/>
            <Setter Property="FontSize"               Value="12"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <!-- ↓ This is the key line — black text on white dropdown background -->
                        <Setter Property="Foreground"  Value="#111111"/>
                        <Setter Property="Background"  Value="#FFFFFF"/>
                        <Setter Property="FontSize"    Value="12"/>
                        <Setter Property="Padding"     Value="8,5"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#7C6FE0"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#5A4FBF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- Resize Thumb -->
        <Style x:Key="ResizeThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{StaticResource AccentBrush}"
                                BorderBrush="White" BorderThickness="1"
                                CornerRadius="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>   <!-- Top bar -->
            <RowDefinition Height="*"/>    <!-- Body -->
            <RowDefinition Height="32"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════
             TOP BAR
             ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                <TextBlock Text="🎨" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Bulk Image Generator"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,28,0"/>
                <Button Content="📂 Load Template"
                        Command="{Binding LoadTemplateCommand}"
                        Style="{StaticResource GhostButton}" Margin="0,0,6,0"/>
                <Button Content="💾 Save Template"
                        Command="{Binding SaveTemplateCommand}"
                        Style="{StaticResource GhostButton}" Margin="0,0,6,0"/>
                <Button Content="🖼 Background Image"
                        Command="{Binding LoadBackgroundImageCommand}"
                        Style="{StaticResource GhostButton}"/>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             BODY — 3 columns
             ══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>  <!-- Left panel -->
                <ColumnDefinition Width="*"/>    <!-- Canvas -->
                <ColumnDefinition Width="260"/>  <!-- Properties panel -->
            </Grid.ColumnDefinitions>

            <!-- ══ LEFT PANEL ═══════════════════════════════════════════════ -->
            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">

                        <!-- Placeholders -->
                        <TextBlock Text="Placeholders" Style="{StaticResource SectionLabel}"/>
                        <Button Content="＋ Add Text Block"
                                Command="{Binding AddTextPlaceholderCommand}"
                                Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,6"/>
                        <Button Content="＋ Add Image Box"
                                Command="{Binding AddImagePlaceholderCommand}"
                                Style="{StaticResource AccentButton}"
                                Background="#4E7FD4"
                                HorizontalAlignment="Stretch" Margin="0,0,0,6"/>
                        <Button Content="🗑 Delete Selected"
                                Command="{Binding DeleteSelectedPlaceholderCommand}"
                                Style="{StaticResource DangerButton}"
                                HorizontalAlignment="Stretch"/>

                        <!-- Canvas Size -->
                        <TextBlock Text="Canvas Size (px)" Style="{StaticResource SectionLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}"
                                     Text="{Binding CurrentTemplate.CanvasWidth,
                                         UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="1" Text="×"
                                       Foreground="{StaticResource TextSecondary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="2" Style="{StaticResource DarkTextBox}"
                                     Text="{Binding CurrentTemplate.CanvasHeight,
                                         UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <!-- Output Format -->
                        <TextBlock Text="Output Format" Style="{StaticResource SectionLabel}"/>
                        <ComboBox Style="{StaticResource DarkComboBox}"
                                  SelectedValue="{Binding CurrentTemplate.OutputFormat}"
                                  SelectedValuePath="Content"
                                  Margin="0,0,0,6">
                            <ComboBoxItem Content="jpeg"/>
                            <ComboBoxItem Content="png"/>
                        </ComboBox>

                        <TextBlock Text="JPEG Quality"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11" Margin="0,0,0,2"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" Minimum="1" Maximum="100"
                                    Value="{Binding CurrentTemplate.OutputQuality}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CurrentTemplate.OutputQuality}"
                                       Foreground="{StaticResource TextPrimary}"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </Grid>

                        <TextBlock Text="Output Filename Column"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11" Margin="0,8,0,2"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding FileNameColumn, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Excel column header to use as filename (optional)"/>

                        <!-- Image Assets Folder -->
                        <TextBlock Text="Image Assets Folder" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="Image columns in Excel use filenames only (e.g. alice.jpg)"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="10" TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#1E1E2E"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="6,5">
                                <TextBlock Text="{Binding AssetsFolderName}"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="11" TextTrimming="CharacterEllipsis"/>
                            </Border>
                            <Button Grid.Column="1" Content="…"
                                    Command="{Binding BrowseAssetsFolderCommand}"
                                    Style="{StaticResource GhostButton}"
                                    Margin="6,0,0,0" Padding="10,5"/>
                        </Grid>

                        <!-- Excel Import -->
                        <TextBlock Text="Excel Data" Style="{StaticResource SectionLabel}"/>
                        <Button Content="📊 Import Excel (.xlsx / .xls)"
                                Command="{Binding ImportExcelCommand}"
                                Style="{StaticResource SuccessButton}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,6"/>
                        <Border Background="#1E1E2E" CornerRadius="4" Padding="8,6">
                            <StackPanel>
                                <TextBlock Text="{Binding ExcelFileName}"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="11" TextWrapping="Wrap"/>
                                <TextBlock Foreground="{StaticResource TextSecondary}"
                                           FontSize="10" Margin="0,2,0,0">
                                    <Run Text="{Binding ExcelRowCount, Mode=OneWay}"/>
                                    <Run Text=" rows detected"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Output Directory -->
                        <TextBlock Text="Output Folder" Style="{StaticResource SectionLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}"
                                     Text="{Binding OutputDirectory}"
                                     IsReadOnly="True" FontSize="10"/>
                            <Button Grid.Column="1" Content="…"
                                    Command="{Binding BrowseOutputDirectoryCommand}"
                                    Style="{StaticResource GhostButton}"
                                    Margin="6,0,0,0" Padding="10,5"/>
                        </Grid>

                        <!-- Generate -->
                        <TextBlock Text="Generate" Style="{StaticResource SectionLabel}"/>
                        <Button Content="⚡ Generate All Images"
                                Command="{Binding GenerateAllCommand}"
                                Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Stretch"
                                FontSize="13" Padding="12,10"
                                Margin="0,0,0,6">
                            <Button.IsEnabled>
                                <Binding Path="IsGenerating"
                                         Converter="{StaticResource BoolToVisibility}"
                                         ConverterParameter="Inverse"/>
                            </Button.IsEnabled>
                        </Button>

                        <Button Content="⛔ Cancel Generation"
                                Command="{Binding GenerateAllCancelCommand}"
                                Style="{StaticResource DangerButton}"
                                HorizontalAlignment="Stretch"
                                Visibility="{Binding IsGenerating,
                                    Converter={StaticResource BoolToVisibility}}"/>

                        <ProgressBar Height="8" Margin="0,10,0,4"
                                     Minimum="0"
                                     Maximum="{Binding ProgressMax}"
                                     Value="{Binding ProgressValue}"
                                     Background="#1E1E2E"
                                     Foreground="{StaticResource AccentBrush}"/>

                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="10" TextWrapping="Wrap"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ══ CENTER CANVAS ═════════════════════════════════════════════ -->
            <Border Grid.Column="1" Background="#16161F">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="40">

                        <Border>
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="24"
                                                  ShadowDepth="6" Opacity="0.7"/>
                            </Border.Effect>

                            <Grid Width="{Binding CanvasWidth}"
                                  Height="{Binding CanvasHeight}"
                                  ClipToBounds="True">

                                <!-- Background image -->
                                <Image Source="{Binding BackgroundImagePath}"
                                       Stretch="Fill"
                                       IsHitTestVisible="False"/>

                                <!-- Empty state hint -->
                                <TextBlock IsHitTestVisible="False"
                                           Text="Load a background image to start"
                                           Foreground="#33FFFFFF" FontSize="16"
                                           FontStyle="Italic"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Visibility>
                                        <Binding Path="BackgroundImagePath"
                                                 Converter="{StaticResource BoolToVisibility}"
                                                 ConverterParameter="Inverse"/>
                                    </TextBlock.Visibility>
                                </TextBlock>

                                <!-- Placeholder ItemsControl -->
                                <ItemsControl ItemsSource="{Binding Placeholders}">

                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas Background="Transparent"
                                                    MouseLeftButtonDown="Canvas_MouseDown"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                            <Setter Property="Canvas.Top"  Value="{Binding Top}"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Width="{Binding Width}"
                                                  Height="{Binding Height}"
                                                  Cursor="SizeAll"
                                                  MouseLeftButtonDown="Placeholder_MouseLeftButtonDown"
                                                  MouseMove="Placeholder_MouseMove"
                                                  MouseLeftButtonUp="Placeholder_MouseLeftButtonUp">

                                                <!-- Body -->
                                                <Border BorderThickness="1.5" CornerRadius="3">
                                                    <Border.BorderBrush>
                                                        <SolidColorBrush Color="#7C6FE0"/>
                                                    </Border.BorderBrush>
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#7C6FE0" Opacity="0.18"/>
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding DisplayLabel}"
                                                               Foreground="White"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               IsHitTestVisible="False"/>
                                                </Border>

                                                <!-- Selection ring -->
                                                <Border BorderThickness="2" CornerRadius="3"
                                                        IsHitTestVisible="False"
                                                        Visibility="{Binding IsSelected,
                                                            Converter={StaticResource BoolToVisibility}}">
                                                    <Border.BorderBrush>
                                                        <SolidColorBrush Color="#FFFFFF" Opacity="0.9"/>
                                                    </Border.BorderBrush>
                                                </Border>

                                                <!-- Resize handles -->
                                                <Canvas IsHitTestVisible="True"
                                                        Visibility="{Binding IsSelected,
                                                            Converter={StaticResource BoolToVisibility}}">
                                                    <Thumb Canvas.Left="-5"  Canvas.Top="-5"
                                                           Width="10" Height="10" Tag="TL" Cursor="SizeNWSE"
                                                           DragDelta="ResizeThumb_DragDelta"
                                                           Style="{StaticResource ResizeThumbStyle}"/>
                                                    <Thumb Canvas.Left="{Binding HalfWidthOffset}" Canvas.Top="-5"
                                                           Width="10" Height="10" Tag="TC" Cursor="SizeNS"
                                                           DragDelta="ResizeThumb_DragDelta"
                                                           Style="{StaticResource ResizeThumbStyle}"/>
                                                    <Thumb Canvas.Left="{Binding WidthOffset}" Canvas.Top="-5"
                                                           Width="10" Height="10" Tag="TR" Cursor="SizeNESW"
                                                           DragDelta="ResizeThumb_DragDelta"
                                                           Style="{StaticResource ResizeThumbStyle}"/>
                                                    <Thumb Canvas.Left="-5" Canvas.Top="{Binding HalfHeightOffset}"
                                                           Width="10" Height="10" Tag="ML" Cursor="SizeWE"
                                                           DragDelta="ResizeThumb_DragDelta"
                                                           Style="{StaticResource ResizeThumbStyle}"/>
                                                    <Thumb Canvas.Left="{Binding WidthOffset}" Canvas.Top="{Binding HalfHeightOffset}"
                                                           Width="10" Height="10" Tag="MR" Cursor="SizeWE"
                                                           DragDelta="ResizeThumb_DragDelta"
                                                           Style="{StaticResource ResizeThumbStyle}"/>
                                                    <Thumb Canvas.Left="-5" Canvas.Top="{Binding HeightOffset}"
                                                           Width="10" Height="10" Tag="BL" Cursor="SizeNESW"
                                                           DragDelta="ResizeThumb_DragDelta"
                                                           Style="{StaticResource ResizeThumbStyle}"/>
                                                    <Thumb Canvas.Left="{Binding HalfWidthOffset}" Canvas.Top="{Binding HeightOffset}"
                                                           Width="10" Height="10" Tag="BC" Cursor="SizeNS"
                                                           DragDelta="ResizeThumb_DragDelta"
                                                           Style="{StaticResource ResizeThumbStyle}"/>
                                                    <Thumb Canvas.Left="{Binding WidthOffset}" Canvas.Top="{Binding HeightOffset}"
                                                           Width="10" Height="10" Tag="BR" Cursor="SizeNWSE"
                                                           DragDelta="ResizeThumb_DragDelta"
                                                           Style="{StaticResource ResizeThumbStyle}"/>
                                                </Canvas>

                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>

                                </ItemsControl>

                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Border>

            <!-- ══ RIGHT PROPERTIES PANEL ════════════════════════════════════ -->
            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <!-- No selection state -->
                    <TextBlock Text="Select a placeholder&#10;to edit its properties."
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="13" FontStyle="Italic"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasSelection,
                                   Converter={StaticResource BoolToVisibility},
                                   ConverterParameter=Inverse}"/>

                    <!-- Properties form -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasSelection,
                                      Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Margin="14"
                                    DataContext="{Binding SelectedPlaceholder}">

                            <TextBlock Text="Placeholder Properties"
                                       Style="{StaticResource SectionLabel}"
                                       Margin="0,4,0,10"/>

                            <!-- Variable Name -->
                            <TextBlock Text="Variable Name"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="11" Margin="0,0,0,2"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding VariableName,
                                         UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <!-- Type -->
                            <TextBlock Text="Type"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="11" Margin="0,0,0,2"/>
                            <ComboBox Style="{StaticResource DarkComboBox}"
                                      SelectedValue="{Binding Type}"
                                      SelectedValuePath="Content"
                                      Margin="0,0,0,12">
                                <ComboBoxItem Content="text"/>
                                <ComboBoxItem Content="image"/>
                            </ComboBox>

                            <!-- Position & Size -->
                            <TextBlock Text="Position &amp; Size"
                                       Style="{StaticResource SectionLabel}"/>
                            <Grid Margin="0,4,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="X"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11" Margin="0,0,0,2"/>
                                <TextBox   Grid.Row="1" Grid.Column="0"
                                           Style="{StaticResource DarkTextBox}"
                                           Text="{Binding Left, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Y"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11" Margin="0,0,0,2"/>
                                <TextBox   Grid.Row="1" Grid.Column="2"
                                           Style="{StaticResource DarkTextBox}"
                                           Text="{Binding Top, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Width"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11" Margin="0,0,0,2"/>
                                <TextBox   Grid.Row="4" Grid.Column="0"
                                           Style="{StaticResource DarkTextBox}"
                                           Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="3" Grid.Column="2" Text="Height"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11" Margin="0,0,0,2"/>
                                <TextBox   Grid.Row="4" Grid.Column="2"
                                           Style="{StaticResource DarkTextBox}"
                                           Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <!-- TEXT STYLE (shown only when type = text) -->
                            <StackPanel Visibility="{Binding IsTextType,
                                            Converter={StaticResource BoolToVisibility}}">

                                <TextBlock Text="Text Style" Style="{StaticResource SectionLabel}"/>

                                <TextBlock Text="Font Family"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11" Margin="0,0,0,2"/>
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding FontFamily, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,8"/>

                                <TextBlock Text="Font Size (pt)"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11" Margin="0,0,0,2"/>
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,8"/>

                                <TextBlock Text="Color (#AARRGGBB)"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11" Margin="0,0,0,2"/>
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding TextColor, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,8"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <CheckBox Content="Bold"
                                              IsChecked="{Binding IsBold}"
                                              Foreground="{StaticResource TextPrimary}"
                                              Margin="0,0,16,0"/>
                                    <CheckBox Content="Italic"
                                              IsChecked="{Binding IsItalic}"
                                              Foreground="{StaticResource TextPrimary}"/>
                                </StackPanel>

                                <TextBlock Text="Horizontal Alignment"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11" Margin="0,0,0,2"/>
                                <ComboBox Style="{StaticResource DarkComboBox}"
                                          SelectedValue="{Binding Alignment}"
                                          SelectedValuePath="Content"
                                          Margin="0,0,0,8">
                                    <ComboBoxItem Content="left"/>
                                    <ComboBoxItem Content="center"/>
                                    <ComboBoxItem Content="right"/>
                                </ComboBox>

                                <TextBlock Text="Vertical Alignment"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11" Margin="0,0,0,2"/>
                                <ComboBox Style="{StaticResource DarkComboBox}"
                                          SelectedValue="{Binding VerticalAlignment}"
                                          SelectedValuePath="Content"
                                          Margin="0,0,0,8">
                                    <ComboBoxItem Content="top"/>
                                    <ComboBoxItem Content="middle"/>
                                    <ComboBoxItem Content="bottom"/>
                                </ComboBox>

                                <CheckBox Content="Word Wrap"
                                          IsChecked="{Binding WordWrap}"
                                          Foreground="{StaticResource TextPrimary}"
                                          Margin="0,0,0,8"/>
                            </StackPanel>

                            <!-- IMAGE STYLE (shown only when type = image) -->
                            <StackPanel Visibility="{Binding IsImageType,
                                            Converter={StaticResource BoolToVisibility}}">

                                <TextBlock Text="Image Style" Style="{StaticResource SectionLabel}"/>

                                <TextBlock Text="Fit Mode"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11" Margin="0,0,0,2"/>
                                <ComboBox Style="{StaticResource DarkComboBox}"
                                          SelectedValue="{Binding FitMode}"
                                          SelectedValuePath="Content"
                                          Margin="0,0,0,8">
                                    <ComboBoxItem Content="cover"/>
                                    <ComboBoxItem Content="contain"/>
                                    <ComboBoxItem Content="stretch"/>
                                </ComboBox>

                                <TextBlock Text="Corner Radius (px)"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11" Margin="0,0,0,2"/>
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding CornerRadius,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Set to half of Width/Height for a perfect circle"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             STATUS BAR
             ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11" VerticalAlignment="Center">
                    <Run Text="{Binding ProgressValue, Mode=OneWay}"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding ProgressMax, Mode=OneWay}"/>
                    <Run Text=" images"/>
                </TextBlock>
            </Grid>
        </Border>

    </Grid>
</Window>
